# Prevent execution of lifecycle scripts (preinstall, postinstall, etc.)
# Primary attack vector for Shai-Hulud worm and most malicious packages.
ignore-scripts=true

# Block git dependencies from overriding the git binary path to bypass ignore-scripts.
# Requires npm 11.10.0+.
allow-git=none

# Pin exact versions instead of semver ranges.
# The Axios compromise (March 2026) exploited ^1.14.0 auto-upgrading to poisoned 1.14.1.
save-exact=true

# Refuse to install versions published less than 3 days ago.
# Most malicious versions are detected and removed within hours.
# Requires npm 11.10.0+.
min-release-age=3

# Use project-local cache to avoid dependency on global ~/.npm state.
cache=.npm-cache

audit=true
engine-strict=true
package-lock=true
fund=false
