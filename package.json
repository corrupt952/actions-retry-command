{
  "name": "actions-retry-command",
  "description": "Retries a shell command on failure with real-time output streaming",
  "version": "2.0.0",
  "author": "corrupt952",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/corrupt952/actions-retry-command",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corrupt952/actions-retry-command.git"
  },
  "bugs": {
    "url": "https://github.com/corrupt952/actions-retry-command/issues"
  },
  "keywords": [
    "actions",
    "retry"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "package": "rm -rf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "all": "npm run check && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/exec": "1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@jest/globals": "30.2.0",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.3",
    "jest": "30.2.0",
    "rollup": "4.60.1",
    "ts-jest": "29.4.6",
    "ts-jest-resolver": "2.0.1",
    "typescript": "5.9.3"
  }
}
